# HelpersHelp Backend Configuration

# Database
# HELPERSHELP_DB_PATH=/path/to/helpershelp.db

# Model Cache
# HELPERSHELP_MODEL_CACHE_DIR=/path/to/.model_cache

# Offline Mode (prevents downloading models from Hugging Face)
# HELPERSHELP_OFFLINE=0

# Ollama Configuration (for text generation)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# BGE-M3 Embedding Model (local path - optional)
# BGE_M3_LOCAL_PATH=/path/to/bge-m3

# Sync Loop (background email sync)
# HELPERSHELP_ENABLE_SYNC_LOOP=0
